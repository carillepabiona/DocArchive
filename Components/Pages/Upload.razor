@page "/upload"
@inject IJSRuntime JS
@inject HttpClient Http
@inject NavigationManager Nav
@layout MainLayout
@using Microsoft.Maui.Storage
@using DocArchive.Models
@using System.Net.Http.Json

<link href="css/upload.css" rel="stylesheet" />

@if (showNotification)
{
    <div class="toast @(isSuccess ? "success" : "error")">
        <i class="fa-solid @(isSuccess ? "fa-circle-check" : "fa-circle-xmark")"></i>
        <span>@notificationMessage</span>
    </div>
}

<div class="content">
    <div class="upload-container">

        <div class="upload-box">

            <h1>UPLOAD DOCUMENT</h1>
            <p>File Explorer Style Upload System</p>

            <!-- FILE PICKER -->
            <div class="preview-section">
                @if (!string.IsNullOrEmpty(previewImage))
                {
                    <div class="document-preview" @onclick="TriggerFileInput">
                        <img src="@previewImage" />
                    </div>
                }
                else
                {
                    <div class="document-preview empty" @onclick="TriggerFileInput">
                        <p>Select File</p>
                    </div>
                }

                <InputFile OnChange="HandleFileSelected" style="display:none" />
            </div>

            @if (!string.IsNullOrEmpty(selectedFileName))
            {
                <div class="file-name">@selectedFileName</div>
            }

            <!-- CATEGORY -->
            <div class="section">
                <label>Category</label>

                <select @bind="selectedCategoryId">
                    <option value="0">-- Select Category --</option>
                    @foreach (var cat in categories)
                    {
                        <option value="@cat.Id">@cat.Name</option>
                    }
                </select>
            </div>

            <!-- FOLDER (FROM DATABASE) -->
            <div class="section">
                <label>Folder</label>

                <select @bind="selectedFolderId">
                    <option value="0">-- Select Folder --</option>

                    @foreach (var folder in folders)
                    {
                        <option value="@folder.Id">@folder.Name</option>
                    }

                    <option value="-1">+ Create New Folder</option>
                </select>

                @if (selectedFolderId == -1)
                {
                    <input class="input"
                           placeholder="New folder name"
                           @bind="newFolderName" />

                    <button @onclick="CreateFolder">
                        Save Folder
                    </button>
                }
            </div>

            <!-- UPLOAD -->
            <button class="upload-button" @onclick="UploadDocument">
                Upload Document
            </button>

        </div>
    </div>
</div>

@code {

    // FILE
    private IBrowserFile selectedFile;
    private string selectedFileName = "";
    private string previewImage = "";

    // CATEGORY
    private int selectedCategoryId = 0;
    private List<Category> categories = new();

    // FOLDER (DB BASED)
    private int selectedFolderId = 0;
    private string newFolderName = "";
    private List<Folder> folders = new();

    // NOTIFICATION
    private bool showNotification = false;
    private string notificationMessage = "";
    private bool isSuccess = true;

    // INIT
    protected override async Task OnInitializedAsync()
    {
        await LoadCategories();
        await LoadFolders();
    }

    // =========================
    // LOAD CATEGORIES
    // =========================
    private async Task LoadCategories()
    {
        try
        {
            categories = await Http.GetFromJsonAsync<List<Category>>("api/categories")
                         ?? new List<Category>();
        }
        catch
        {
            categories = new();
        }
    }

    // =========================
    // LOAD FOLDERS FROM DB
    // =========================
    private async Task LoadFolders()
    {
        try
        {
            folders = await Http.GetFromJsonAsync<List<Folder>>("api/folders")
                      ?? new List<Folder>();
        }
        catch
        {
            folders = new();
        }
    }

    // =========================
    // FILE PICKER
    // =========================
    private async Task TriggerFileInput()
    {
        await JS.InvokeVoidAsync("eval",
            "document.querySelector('input[type=file]').click()");
    }

    private async Task HandleFileSelected(InputFileChangeEventArgs e)
    {
        selectedFile = e.File;
        selectedFileName = e.File.Name;

        if (e.File.ContentType.StartsWith("image/"))
        {
            var buffer = new byte[e.File.Size];
            await e.File.OpenReadStream().ReadAsync(buffer);

            previewImage =
                $"data:{e.File.ContentType};base64,{Convert.ToBase64String(buffer)}";
        }
    }

    // =========================
    // CREATE FOLDER (DB)
    // =========================
    private async Task CreateFolder()
    {
        if (string.IsNullOrWhiteSpace(newFolderName))
        {
            ShowNotification("Folder name required", false);
            return;
        }

        var folder = new Folder
        {
            Name = newFolderName
        };

        var response = await Http.PostAsJsonAsync("api/folders", folder);

        if (response.IsSuccessStatusCode)
        {
            var created = await response.Content.ReadFromJsonAsync<Folder>();

            folders.Add(created);

            selectedFolderId = created.Id;
            newFolderName = "";

            ShowNotification("Folder created!", true);
        }
        else
        {
            ShowNotification("Failed to create folder", false);
        }
    }

    // =========================
    // UPLOAD
    // =========================
    private async Task UploadDocument()
    {
        if (selectedFile == null)
        {
            ShowNotification("Select file first", false);
            return;
        }

        if (selectedCategoryId == 0)
        {
            ShowNotification("Select category", false);
            return;
        }

        if (selectedFolderId == 0)
        {
            ShowNotification("Select folder", false);
            return;
        }

        var token = await SecureStorage.GetAsync("jwt_token");

        Http.DefaultRequestHeaders.Authorization =
            new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);

        var content = new MultipartFormDataContent();

        var stream = selectedFile.OpenReadStream(50 * 1024 * 1024);
        var fileContent = new StreamContent(stream);

        fileContent.Headers.ContentType =
            new System.Net.Http.Headers.MediaTypeHeaderValue(selectedFile.ContentType);

        content.Add(fileContent, "File", selectedFile.Name);
        content.Add(new StringContent(Path.GetFileNameWithoutExtension(selectedFile.Name)), "Title");
        content.Add(new StringContent(selectedCategoryId.ToString()), "CategoryId");
        content.Add(new StringContent(selectedFolderId.ToString()), "FolderId");

        var response = await Http.PostAsync("api/documents/upload", content);

        if (response.IsSuccessStatusCode)
        {
            ShowNotification("Upload successful!", true);

            selectedFile = null;
            selectedFileName = "";
            previewImage = "";
            selectedCategoryId = 0;
            selectedFolderId = 0;
        }
        else
        {
            var error = await response.Content.ReadAsStringAsync();
            ShowNotification(error, false);
        }
    }

    // =========================
    // NOTIFICATION
    // =========================
    private async void ShowNotification(string message, bool success)
    {
        notificationMessage = message;
        isSuccess = success;
        showNotification = true;

        StateHasChanged();

        await Task.Delay(2500);

        showNotification = false;
        StateHasChanged();
    }
}