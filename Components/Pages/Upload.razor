@page "/upload"
@inject IJSRuntime JS
@inject HttpClient Http
@inject NavigationManager Nav
@layout MainLayout
@using Microsoft.Maui.Storage
@using DocArchive.Models
@using DocArchive.Services

<link href="css/upload.css" rel="stylesheet" />

<!-- ✅ TOAST NOTIFICATION -->
@if (showNotification)
{
    <div class="toast @(isSuccess ? "success" : "error")">
        <i class="fa-solid @(isSuccess ? "fa-circle-check" : "fa-circle-xmark")"></i>
        <span>@notificationMessage</span>
    </div>
}

<div class="content">
    <div class="upload-container">

        <div class="upload-box">

            <h1>UPLOAD DOCUMENT</h1>
            <p>File Explorer Style Upload System</p>

            <!-- FILE -->
            <div class="preview-section">

                @if (!string.IsNullOrEmpty(previewImage))
                {
                    <div class="document-preview" @onclick="TriggerFileInput">
                        <img src="@previewImage" />
                    </div>
                }
                else
                {
                    <div class="document-preview empty" @onclick="TriggerFileInput">
                        <p>Select File</p>
                    </div>
                }

                <InputFile OnChange="HandleFileSelected" style="display:none" />
            </div>

            @if (!string.IsNullOrEmpty(selectedFileName))
            {
                <div class="file-name">@selectedFileName</div>
            }

            <!-- CATEGORY -->
            <div class="section">

                <label>Category</label>

                <select @bind="selectedCategoryId">
                    <option value="0">-- Select Category --</option>

                    @foreach (var cat in categories)
                    {
                        <option value="@cat.Id">@cat.Name</option>
                    }

                    <option value="-1">+ Add New Category</option>
                </select>

                @if (selectedCategoryId == -1)
                {
                    <input class="input"
                           placeholder="Enter new category name"
                           @bind="newCategoryName" />

                    <button @onclick="CreateCategory">
                        Save Category
                    </button>
                }

            </div>

            <!-- FOLDER -->
            <div class="section">

                <label>Folder</label>

                <select @bind="selectedFolder">
                    <option value="">-- Select Folder --</option>

                    @foreach (var folder in folders)
                    {
                        <option value="@folder">@folder</option>
                    }

                    <option value="__new">+ Create New Folder</option>
                </select>

                @if (selectedFolder == "__new")
                {
                    <input class="input"
                           placeholder="New folder name"
                           @bind="newFolderName" />

                    <button @onclick="CreateFolder">
                        Save Folder
                    </button>
                }

            </div>

            <!-- UPLOAD -->
            <button class="upload-button" @onclick="UploadDocument">
                Upload Document
            </button>

        </div>

    </div>
</div>

@code {

    private string selectedFileName = "";
    private string previewImage = "";
    private IBrowserFile selectedFile;

    private int selectedCategoryId = 0;
    private string newCategoryName = "";
    private List<Category> categories = new();

    private string selectedFolder = "";
    private string newFolderName = "";
    private List<string> folders = new();

    // ✅ NEW NOTIFICATION SYSTEM
    private bool showNotification = false;
    private string notificationMessage = "";
    private bool isSuccess = true;

    protected override async Task OnInitializedAsync()
    {
        await LoadCategories();
        LoadFolders();
    }

    // =========================
    // LOAD CATEGORIES
    // =========================
    private async Task LoadCategories()
    {
        try
        {
            var response = await Http.GetAsync("api/categories");

            if (response.IsSuccessStatusCode)
            {
                categories = await response.Content.ReadFromJsonAsync<List<Category>>()
                             ?? new List<Category>();
            }
        }
        catch
        {
            categories = new List<Category>();
        }
    }

    // =========================
    // LOAD FOLDERS
    // =========================
    private void LoadFolders()
    {
        var basePath = Path.Combine(FileSystem.AppDataDirectory, "documents");

        if (Directory.Exists(basePath))
        {
            folders = Directory.GetDirectories(basePath)
                .Select(Path.GetFileName)
                .ToList();
        }
        else
        {
            folders = new List<string>();
        }
    }

    // =========================
    // FILE PICKER
    // =========================
    private async Task TriggerFileInput()
    {
        await JS.InvokeVoidAsync("eval",
            "document.querySelector('input[type=file]').click()");
    }

    private async Task HandleFileSelected(InputFileChangeEventArgs e)
    {
        selectedFile = e.File;
        selectedFileName = e.File.Name;

        if (e.File.ContentType.StartsWith("image/"))
        {
            var buffer = new byte[e.File.Size];
            await e.File.OpenReadStream().ReadAsync(buffer);
            previewImage = $"data:{e.File.ContentType};base64,{Convert.ToBase64String(buffer)}";
        }
    }

    // =========================
    // CREATE CATEGORY
    // =========================
    private async Task CreateCategory()
    {
        if (string.IsNullOrWhiteSpace(newCategoryName))
        {
            ShowNotification("Category name required", false);
            return;
        }

        var newCat = new Category { Name = newCategoryName };

        var response = await Http.PostAsJsonAsync("api/categories", newCat);

        if (response.IsSuccessStatusCode)
        {
            var created = await response.Content.ReadFromJsonAsync<Category>();

            categories.Add(created);

            selectedCategoryId = created.Id;
            newCategoryName = "";

            ShowNotification("Category created!", true);
        }
        else
        {
            ShowNotification("Failed to create category", false);
        }
    }

    // =========================
    // CREATE FOLDER
    // =========================
    private void CreateFolder()
    {
        if (string.IsNullOrWhiteSpace(newFolderName))
        {
            ShowNotification("Folder name required", false);
            return;
        }

        if (!folders.Contains(newFolderName))
        {
            folders.Add(newFolderName);
        }

        selectedFolder = newFolderName;
        newFolderName = "";

        ShowNotification("Folder created!", true);
    }

    // =========================
    // UPLOAD DOCUMENT
    // =========================
    private async Task UploadDocument()
    {
        if (selectedFile == null)
        {
            ShowNotification("Select file first", false);
            return;
        }

        if (selectedCategoryId <= 0)
        {
            ShowNotification("Select category", false);
            return;
        }

        if (string.IsNullOrWhiteSpace(selectedFolder))
        {
            ShowNotification("Select folder", false);
            return;
        }

        var token = await SecureStorage.GetAsync("jwt_token");

        if (string.IsNullOrEmpty(token))
        {
            ShowNotification("User not authenticated", false);
            return;
        }

        Http.DefaultRequestHeaders.Authorization =
            new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);

        var content = new MultipartFormDataContent();

        var stream = selectedFile.OpenReadStream(50 * 1024 * 1024);
        var fileContent = new StreamContent(stream);

        fileContent.Headers.ContentType =
            new System.Net.Http.Headers.MediaTypeHeaderValue(selectedFile.ContentType);

        content.Add(fileContent, "File", selectedFile.Name);
        content.Add(new StringContent(Path.GetFileNameWithoutExtension(selectedFile.Name)), "Title");
        content.Add(new StringContent(selectedCategoryId.ToString()), "CategoryId");
        content.Add(new StringContent("false"), "IsConfidential");

        var response = await Http.PostAsync("api/documents/upload", content);

        if (response.IsSuccessStatusCode)
        {
            ShowNotification("Document uploaded successfully!", true);

            selectedFile = null;
            selectedFileName = "";
            previewImage = "";
            selectedCategoryId = 0;
            selectedFolder = "";
        }
        else
        {
            var error = await response.Content.ReadAsStringAsync();
            ShowNotification($"Upload failed: {error}", false);
        }
    }

    // =========================
    // NOTIFICATION HELPER
    // =========================
    private async void ShowNotification(string message, bool success)
    {
        notificationMessage = message;
        isSuccess = success;
        showNotification = true;

        StateHasChanged();

        await Task.Delay(3000);

        showNotification = false;
        StateHasChanged();
    }
}