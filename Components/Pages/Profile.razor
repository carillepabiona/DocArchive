@page "/profile"
@inject NavigationManager Nav
@using Microsoft.Maui.Storage
@using System.IdentityModel.Tokens.Jwt
@using System.Security.Claims
@using System.Linq

<head>
    <link href="css/profile.css" rel="stylesheet" />
</head>

<div class="profile-container">

    <div class="profile-card">

        <!-- HEADER -->
        <div class="profile-card-header">
            <h1>User Profile</h1>

            <button class="edit-button" @onclick="ToggleEditMode">
                @(isEditMode ? "Cancel" : "Edit")
            </button>
        </div>

        <!-- PROFILE CONTENT (SAME STRUCTURE FOR BOTH MODES) -->
        <div class="profile-content">

            <!-- USER INFO SECTION -->
            <div class="profile-section">
                <div class="avatar-name-section">
                    <div class="avatar-circle">@initials</div>

                    <div class="name-info">
                        <h2>@username</h2>
                        <p class="rank">@fullName</p>
                        <p class="organization">Employee ID: @userCode</p>
                    </div>
                </div>
            </div>

            <!-- EMAIL (READ ONLY) -->
            <div class="profile-row">
                <span class="icon">✉️</span>
                <span class="label">Email:</span>
                <span class="value">@email</span>
            </div>

            <!-- PHONE (EDITABLE ONLY) -->
            <div class="profile-row">
                <span class="icon">📱</span>
                <span class="label">Phone:</span>

                @if (!isEditMode)
                {
                    <span class="value">@phone</span>
                }
                else
                {
                    <input class="inline-input" @bind="editPhone" />
                }
            </div>

            <!-- ADDRESS (EDITABLE ONLY) -->
            <div class="profile-row">
                <span class="icon">📍</span>
                <span class="label">Address:</span>

                @if (!isEditMode)
                {
                    <span class="value">@address</span>
                }
                else
                {
                    <input class="inline-input" @bind="editAddress" />
                }
            </div>

            <!-- ROLE (READ ONLY) -->
            <div class="profile-row">
                <span class="icon">🛡️</span>
                <span class="label">Role:</span>
                <span class="value">@role</span>
            </div>

        </div>

        <!-- ACTION BUTTONS ONLY IN EDIT MODE -->
        @if (isEditMode)
        {
            <div class="form-actions">
                <button class="save-button" @onclick="SaveProfile">
                    Save
                </button>

                <button class="cancel-button" @onclick="ToggleEditMode">
                    Cancel
                </button>
            </div>
        }

    </div>

</div>

@code {

    private bool isEditMode;

    // ===== USER DATA =====
    private string username = "";
    private string fullName = "";
    private string email = "";
    private string phone = "";
    private string address = "";
    private string userCode = "";
    private string role = "";
    private string initials = "";

    // ===== EDIT FIELDS =====
    private string editPhone = "";
    private string editAddress = "";

    protected override async Task OnInitializedAsync()
    {
        await LoadJwtData();
    }

    private async Task LoadJwtData()
    {
        var token = await SecureStorage.GetAsync("jwt_token");

        if (string.IsNullOrEmpty(token))
        {
            Nav.NavigateTo("/");
            return;
        }

        var handler = new JwtSecurityTokenHandler();
        var jwt = handler.ReadJwtToken(token);

        username = jwt.Claims.FirstOrDefault(c => c.Type == ClaimTypes.Name)?.Value ?? "";
        role = jwt.Claims.FirstOrDefault(c => c.Type == ClaimTypes.Role)?.Value ?? "Employee";

        fullName = jwt.Claims.FirstOrDefault(c => c.Type == "fullName")?.Value ?? "";
        email = jwt.Claims.FirstOrDefault(c => c.Type == "email")?.Value ?? "";
        phone = jwt.Claims.FirstOrDefault(c => c.Type == "phone")?.Value ?? "";
        address = jwt.Claims.FirstOrDefault(c => c.Type == "address")?.Value ?? "";
        userCode = jwt.Claims.FirstOrDefault(c => c.Type == "userCode")?.Value ?? "";

        if (string.IsNullOrWhiteSpace(fullName))
            fullName = username;

        initials = string.Join("",
            fullName.Split(' ', StringSplitOptions.RemoveEmptyEntries)
            .Select(x => x[0])
        ).ToUpper();

        editPhone = phone;
        editAddress = address;
    }

    private void ToggleEditMode()
    {
        if (isEditMode)
        {
            editPhone = phone;
            editAddress = address;
        }

        isEditMode = !isEditMode;
    }

    private async Task SaveProfile()
    {
        // TODO: API update call here

        phone = editPhone;
        address = editAddress;

        isEditMode = false;
    }
}