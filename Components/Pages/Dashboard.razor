@page "/dashboard"
@layout MainLayout
@inject NavigationManager Nav
@using Microsoft.Maui.Storage
@using DocArchive.Models
@using DocArchive.Services

<div class="content">
    <!-- Dashboard Header -->
    <div class="dashboard-header">
        <h2>DASHBOARD</h2>
        <p>Document Archiving & Security Management System</p>
    </div>

    <!-- Recently Viewed Files Section -->
    <div class="recently-viewed-section">
        <div class="section-title">
            <span class="icon">📋</span>
            <h3>Recently Viewed Files</h3>
        </div>

        <div class="file-cards">
            @foreach (var file in recentFiles)
            {
                <div class="file-card">
                    <div class="file-icon">📄</div>
                    <div class="file-details">
                        <h4>@file.Title</h4>
                        <p class="file-type">@file.Type</p>
                    </div>
                    <div class="file-meta">
                        <span class="eye-icon">👁️</span>
                        <p>@file.ViewedText</p>
                    </div>
                </div>
            }
        </div>
    </div>

    <!-- Filter Section -->
    <div class="filter-section">
        <input type="text" class="filter-input" placeholder="Filter by User ID or Type" @bind="filterText" />
    </div>

    <!-- Table Section -->
    <div class="table-section">
        <table class="documents-table">
            <thead>
                <tr>
                    <th>User ID</th>
                    <th>Title</th>
                    <th>Type</th>
                    <th>Date</th>
                </tr>
            </thead>
            <tbody>
                @if (filteredDocuments.Count > 0)
                {
                    @foreach (var doc in filteredDocuments)
                    {
                        <tr>
                            <td>@doc.UserId</td>
                            <td>@doc.Title</td>
                            <td>@doc.Type</td>
                            <td>@doc.Date.ToString("MM/dd/yyyy")</td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="4" class="empty-state">No documents found</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@code {
    private List<FileItem> recentFiles = new();
    private List<Document> allDocuments = new();
    private List<Document> filteredDocuments = new();
    private string filterText = "";

    protected override async Task OnInitializedAsync()
    {
        // Sample Recent Files Data
        recentFiles = new List<FileItem>
        {
            new FileItem
            {
                Title = "Intelligence Brief - January 2025",
                Type = "PDF",
                ViewedText = "Viewed about 12 hours ago"
            },
            new FileItem
            {
                Title = "Monthly Report",
                Type = "DOCX",
                ViewedText = "Viewed 2 days ago"
            }
        };

        // Sample Documents Data
        allDocuments = new List<Document>
        {
            new Document
            {
                UserId = "AFP001",
                Title = "Intelligence Brief - January 2025",
                Type = "PDF",
                Date = DateTime.Now.AddDays(-1)
            },
            new Document
            {
                UserId = "AFP002",
                Title = "Monthly Report",
                Type = "DOCX",
                Date = DateTime.Now.AddDays(-3)
            },
            new Document
            {
                UserId = "AFP003",
                Title = "Security Protocol Update",
                Type = "PDF",
                Date = DateTime.Now.AddDays(-5)
            },
            new Document
            {
                UserId = "AFP004",
                Title = "Budget Allocation",
                Type = "XLSX",
                Date = DateTime.Now.AddDays(-7)
            }
        };

        filteredDocuments = allDocuments;
    }

    private void OnFilterTextChanged(string text)
    {
        filterText = text;
        if (string.IsNullOrWhiteSpace(filterText))
        {
            filteredDocuments = allDocuments;
        }
        else
        {
            var lowerFilter = filterText.ToLower();
            filteredDocuments = allDocuments
                .Where(d => d.UserId.ToLower().Contains(lowerFilter) ||
                            d.Type.ToLower().Contains(lowerFilter) ||
                            d.Title.ToLower().Contains(lowerFilter))
                .ToList();
        }
    }

    public class FileItem
    {
        public string Title { get; set; }
        public string Type { get; set; }
        public string ViewedText { get; set; }
    }

    public class Document
    {
        public string UserId { get; set; }
        public string Title { get; set; }
        public string Type { get; set; }
        public DateTime Date { get; set; }
    }
}