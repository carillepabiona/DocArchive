@page "/documents-user"
@inject HttpClient Http
@inject IJSRuntime JS
@layout MainLayout
@implements IDisposable
@using DocArchive.Models
@using System.Net.Http.Json

<link href="css/documents-user.css" rel="stylesheet" />

<div class="content">

    <div class="doc-container">

        <!-- HEADER -->
        <div class="doc-header">
            <h1>My Documents</h1>
            <p>Browse and manage your files</p>
        </div>

        <!-- TOOLBAR -->
        <!-- TOOLBAR -->
        <div class="doc-toolbar">

            <!-- SEARCH -->
            <div class="toolbar-search">
                <input class="search-box"
                       placeholder="🔍 Search documents..."
                       @bind="searchText"
                       @bind:event="oninput" />
            </div>

            <!-- CATEGORY DROPDOWN -->
            <div class="dropdown-wrapper">
                <select class="category-filter" @bind="selectedCategoryId">
                    <option value="0">All Categories</option>
                    @foreach (var cat in categories)
                    {
                        <option value="@cat.Id">@cat.Name</option>
                    }
                </select>
            </div>

        </div>

        <!-- LOADING -->
        @if (isLoading)
        {
            <div class="empty-state">⏳ Loading documents...</div>
        }
        else
        {
            <!-- FILE EXPLORER -->
            <div class="file-explorer">

                <div class="file-header">
                    <div>Name</div>
                    <div>Category</div>
                    <div>Date</div>
                </div>

                @if (!FilteredDocuments.Any())
                {
                    <div class="empty-state">📂 No documents found</div>
                }
                else
                {
                    @foreach (var doc in FilteredDocuments)
                    {
                        <div class="file-row"
                             @onclick="() => ViewFile(doc.FilePath)">

                            <div class="file-name">
                                <span class="icon">@GetFileIcon(doc.FilePath)</span>
                                @doc.Title
                            </div>

                            <div>
                                @GetCategoryName(doc.CategoryId)
                            </div>

                            <div>
                                @doc.CreatedAt.ToString("MMM dd, yyyy")
                            </div>

                        </div>
                    }
                }

            </div>
        }

        <!-- PREVIEW MODAL -->
        @if (!string.IsNullOrEmpty(selectedFile))
        {
            <div class="preview-modal">

                <div class="preview-box">

                    <span class="close" @onclick="ClosePreview">✕</span>

                    @if (IsImage(selectedFile))
                    {
                        <img src="@GetFileUrl(selectedFile)" />
                    }
                    else if (IsPdf(selectedFile))
                    {
                        <iframe src="@GetFileUrl(selectedFile)"></iframe>
                    }
                    else if (IsTextFile(selectedFile))
                    {
                        <div class="text-container">
                            <pre class="text-content">@textContent</pre>
                        </div>
                    }
                    else
                    {
                        <div class="unsupported">
                            ⚠ File preview not supported
                            <br />
                            <a href="@GetFileUrl(selectedFile)" target="_blank">
                                Open File
                            </a>
                        </div>
                    }

                </div>

            </div>
        }

    </div>

</div>

@code {

    private List<Document> documents = new();
    private List<Category> categories = new();

    private string selectedFile = "";
    private string textContent = "";
    private bool isLoading = true;

    private string searchText = "";
    private int selectedCategoryId = 0;

    private System.Timers.Timer? refreshTimer;

    // =========================
    // INIT
    // =========================
    protected override async Task OnInitializedAsync()
    {
        await LoadData();

        refreshTimer = new System.Timers.Timer(10000);
        refreshTimer.Elapsed += async (s, e) =>
        {
            await InvokeAsync(LoadDocuments);
        };

        refreshTimer.AutoReset = true;
        refreshTimer.Start();
    }

    // =========================
    // FILTERED LIST
    // =========================
    private IEnumerable<Document> FilteredDocuments =>
        documents
            .Where(d =>
                (string.IsNullOrWhiteSpace(searchText) ||
                 d.Title.Contains(searchText, StringComparison.OrdinalIgnoreCase))
                &&
                (selectedCategoryId == 0 || d.CategoryId == selectedCategoryId)
            )
            .OrderByDescending(d => d.CreatedAt);

    // =========================
    // LOAD DATA
    // =========================
    private async Task LoadData()
    {
        isLoading = true;

        await Task.WhenAll(
            LoadDocuments(),
            LoadCategories()
        );

        isLoading = false;
        StateHasChanged();
    }

    private async Task LoadDocuments()
    {
        try
        {
            var response = await Http.GetAsync("api/documents");

            if (!response.IsSuccessStatusCode)
            {
                documents = new List<Document>();
                return;
            }

            documents = await response.Content
                .ReadFromJsonAsync<List<Document>>()
                ?? new List<Document>();
        }
        catch
        {
            documents = new List<Document>();
        }

        await InvokeAsync(StateHasChanged);
    }

    private async Task LoadCategories()
    {
        try
        {
            categories = await Http.GetFromJsonAsync<List<Category>>("api/categories")
                         ?? new List<Category>();
        }
        catch
        {
            categories = new List<Category>();
        }
    }

    // =========================
    // FILE HANDLING
    // =========================
    private string GetFileUrl(string path)
    {
        if (string.IsNullOrWhiteSpace(path))
            return "";

        if (path.StartsWith("http"))
            return path;

        return $"{Http.BaseAddress}{path}";
    }

    private async Task ViewFile(string path)
    {
        selectedFile = path;
        textContent = "";

        if (IsTextFile(path))
        {
            try
            {
                textContent = await Http.GetStringAsync(GetFileUrl(path));
            }
            catch
            {
                textContent = "Failed to load text file.";
            }
        }
    }

    private void ClosePreview()
    {
        selectedFile = "";
        textContent = "";
    }

    // =========================
    // FILE TYPES
    // =========================
    private string GetFileIcon(string path)
    {
        path = path.ToLower();

        if (path.EndsWith(".pdf")) return "📄";
        if (path.EndsWith(".txt")) return "📃";
        if (IsImage(path)) return "🖼️";

        return "📁";
    }

    private bool IsImage(string path)
    {
        path = path.ToLower();
        return path.EndsWith(".jpg") ||
               path.EndsWith(".jpeg") ||
               path.EndsWith(".png") ||
               path.EndsWith(".webp");
    }

    private bool IsPdf(string path)
    {
        return path.ToLower().EndsWith(".pdf");
    }

    private bool IsTextFile(string path)
    {
        return path.ToLower().EndsWith(".txt");
    }

    // =========================
    // CATEGORY
    // =========================
    private string GetCategoryName(int id)
    {
        return categories.FirstOrDefault(c => c.Id == id)?.Name ?? "Unknown";
    }

    // =========================
    // CLEANUP
    // =========================
    public void Dispose()
    {
        refreshTimer?.Stop();
        refreshTimer?.Dispose();
    }
}